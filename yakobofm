class DashboardWindow:
    def __init__(self, user_data):
        self.window = tk.Tk()
        self.window.title(f"Logged In: {user_data['username']}")
        self.window.geometry("500x400")
        self.window.resizable(False, False)
        self.window.config(bg="#f4f6f9")

        # Profile Display Box
        card = tk.Frame(self.window, bg="white", highlightbackground="#dcdcdc", highlightthickness=1)
        card.pack(padx=40, pady=40, fill="both", expand=True)

        # Welcome Text
        welcome_lbl = tk.Label(
            card, 
            text=f"Welcome, {user_data['full_name']}!", 
            font=("Arial", 14, "bold"), 
            bg="white", fg="#2c3e50"
        )
        welcome_lbl.pack(pady=20)

        # Helper function to render profile rows beautifully
        def add_profile_field(label, value):
            row_frame = tk.Frame(card, bg="white")
            row_frame.pack(anchor="w", padx=50, pady=6)
            
            lbl_tag = tk.Label(row_frame, text=label, font=("Arial", 10, "bold"), bg="white", fg="#7f8c8d", width=12, anchor="w")
            lbl_tag.pack(side=tk.LEFT)
            
            lbl_val = tk.Label(row_frame, text=value if value else "Not Configured", font=("Arial", 10), bg="white", fg="#2c3e50")
            lbl_val.pack(side=tk.LEFT)

        # Display user variables retrieved live from the database
        add_profile_field("Username:", user_data['username'])
        add_profile_field("Country:", user_data['country'])
        add_profile_field("Phone No:", user_data['phone_number'])

        # --- THE LOGOUT BUTTON ---
        logout_btn = tk.Button(
            card, 
            text="🚪 Log Out Session", 
            font=("Arial", 10, "bold"), 
            bg="#e74c3c", fg="white", 
            activebackground="#c0392b", activeforeground="white",
            padx=15, pady=8, bd=0, cursor="hand2",
            command=self.logout_action
        )
        logout_btn.pack(pady=30)

        self.window.mainloop()

    def logout_action(self):
        """Destroys the current dashboard workspace and drops back to primary sign-in panel"""
        messagebox.showinfo("Session Ended", "You have been logged out successfully.")
        self.window.destroy() 
        create_auth_window()   


