def validate_login(login_username_entry, login_password_entry):
    global root
    username = login_username_entry.get().strip()
    password = login_password_entry.get().strip()

    if not username or not password:
        messagebox.showwarning("Input Error", "Please provide a valid username and password.")
        return

    try:
        conn = mysql.connector.connect(**db_config)
        cursor = conn.cursor(dictionary=True) 
        
        query = "SELECT * FROM users WHERE username = %s AND password = %s"
        cursor.execute(query, (username, password))
        user = cursor.fetchone()
        
        if user:
            root.destroy()  # Shut down the access validation layout portal window
            DashboardWindow(user)  # Switch instantly over to active profile dashboard loop
        else:
            messagebox.showerror("Login Failed", "Invalid username or password configuration.")
            
    except Error as e:
        messagebox.showerror("Database Connection Error", f"Database lookup failure: {e}")
    finally:
        if 'conn' in locals() and conn.is_connected():
            cursor.close()
            conn.close()

def register_user(reg_username_entry, reg_password_entry, reg_fullname_entry, reg_country_entry, reg_phone_entry, user_tree):
    username = reg_username_entry.get().strip()
    password = reg_password_entry.get().strip()
    fullname = reg_fullname_entry.get().strip()
    country = reg_country_entry.get().strip()
    phone = reg_phone_entry.get().strip()

    if not username or not password or not fullname:
        messagebox.showwarning("Input Error", "Fields marked with (*) are required!")
        return

    try:
        conn = mysql.connector.connect(**db_config)
        cursor = conn.cursor()
        
        query = """
            INSERT INTO users (username, password, full_name, country, phone_number)
            VALUES (%s, %s, %s, %s, %s)
        """
        cursor.execute(query, (username, password, fullname, country, phone))
        conn.commit()
        messagebox.showinfo("Success", "Registration Successful! Account created.")
        
        # UI cleaning
        reg_username_entry.delete(0, tk.END)
        reg_password_entry.delete(0, tk.END)
        reg_fullname_entry.delete(0, tk.END)
        reg_country_entry.delete(0, tk.END)
        reg_phone_entry.delete(0, tk.END)
        
        load_table_data(user_tree)
        
    except mysql.connector.IntegrityError:
        messagebox.showerror("Conflict", "Username is already registered in the system.")
    except Error as e:
        messagebox.showerror("Database Error", f"Transaction failure: {e}")
    finally:
        if 'conn' in locals() and conn.is_connected():
            cursor.close()
            conn.close()

def load_table_data(user_tree):
    """Refreshes structural layout items matching current active row arrays inside MySQL"""
    for row in user_tree.get_children():
        user_tree.delete(row)

    try:
        conn = mysql.connector.connect(**db_config)
        cursor = conn.cursor(dictionary=True)
        cursor.execute("SELECT id, username, full_name, country, phone_number FROM users ORDER BY id DESC")
        rows = cursor.fetchall()
        
        for user in rows:
            user_tree.insert('', tk.END, values=(
                user['id'],
                user['username'],
                user['full_name'],
                user['country'] if user['country'] else "—",
                user['phone_number'] if user['phone_number'] else "—"
            ))
    except Error as e:
        print(f"Background parsing failure: {e}")
    finally:
        if 'conn' in locals() and conn.is_connected():
            cursor.close()
            conn.close()


